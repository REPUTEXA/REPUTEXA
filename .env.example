# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/reputexa?schema=public"

# IA — Au moins une clé. Démo landing / avis : un seul moteur par génération (Claude prioritaire si les deux sont définis).
# Claude = nuance rédactionnelle ; OpenAI (gpt-4o-mini) = alternative rapide.
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# Chat widget page d'accueil (/api/chat) — même clé OpenAI. Défaut gpt-4o (meilleure précision tarifs & produit).
# OPENAI_LANDING_CHAT_MODEL=gpt-4o
# OPENAI_LANDING_CHAT_MAX_TOKENS=2500

# Support IA (RAG + chat) — SUPABASE_SERVICE_ROLE_KEY requis pour la mémoire globale & chunks code
# OPENAI_SUPPORT_CHAT_MODEL=gpt-4o
# ANTHROPIC_SUPPORT_LEARNING_MODEL=claude-sonnet-4-6
# Agent conversationnel (route messages) — défaut Sonnet 4.6 si absent :
# ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
# Premier message à l’ouverture du ticket — défaut Haiku 4.5 si absent :
# ANTHROPIC_BOOTSTRAP_MODEL=claude-haiku-4-5
# Indexation : npm run support:index-codebase
# Watcher temps réel (Python) : pip install -r scripts/requirements-watchdog.txt && npm run support:watch-kb
# SUPPORT_KB_DEBOUNCE=4

# Google Maps / Places (autocomplétion adresse + Sniper)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."
MAPS_API_KEY="AIza..."

# Cloudflare Turnstile (captcha invisible — login, signup)
# Créer un site sur https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # Requis pour RAG support (apprentissage + RPC admin_truncate_code_kb), cron, webhooks…

# Banano / Agent Ghost — enrôlement public + lien Wallet signé (min. 32 car. aléatoires en prod)
# BANANO_WALLET_LINK_SECRET="générez-une-longue-chaîne-aléatoire"

# Agent reputexa-sync (tickets caisse) — secret stocké par marchand : profiles.banano_pilotage_ingest_secret (voir migration 197)
# Fallback local uniquement (sans colonne profil) : Bearer = secret + marchand fixe
# BANANO_PILOTAGE_INGEST_SECRET="générez-une-longue-chaîne-aléatoire"
# BANANO_PILOTAGE_INGEST_MERCHANT_ID="uuid-auth-du-marchand"

# URL du programme d'installation Reputexa Sync (Windows), affiché dans Paramètres fidélité
# NEXT_PUBLIC_REPUTEXA_SYNC_WINDOWS_URL="https://…"

# Apple Wallet (.pkpass Banano) — Pass Type ID + Team ID (developer.apple.com)
# Certificats : exporter PEM (WWDR + certificat Pass Type + clé privée) — voir wiki passkit-generator
# APPLE_PASS_TYPE_IDENTIFIER="pass.com.votreid.banano"
# APPLE_TEAM_ID="XXXXXXXXXX"
# Soit chemins fichiers :
# APPLE_WALLET_WWDR_PATH="./certs/wwdr.pem"
# APPLE_WALLET_SIGNER_CERT_PATH="./certs/pass.pem"
# APPLE_WALLET_SIGNER_KEY_PATH="./certs/pass.key"
# APPLE_WALLET_SIGNER_KEY_PASSPHRASE="mot-de-passe-export-openssl"
# Soit contenu PEM multiligne (Vercel : secrets) :
# APPLE_WALLET_WWDR_PEM="-----BEGIN CERTIFICATE-----\n..."
# APPLE_WALLET_SIGNER_CERT_PEM="-----BEGIN CERTIFICATE-----\n..."
# APPLE_WALLET_SIGNER_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n..."
# Alias historiques acceptés : APPLE_WWDR_CERT_PATH, APPLE_PASS_CERT_PATH, APPLE_PASS_KEY_PATH, APPLE_PASS_KEY_PASSPHRASE
# Ou base64 (déploiement) :
# APPLE_PASS_CERTIFICATE_BASE64="..."
# APPLE_PASS_PRIVATE_KEY="-----BEGIN..." ou chaîne base64 ; sinon APPLE_PASS_PRIVATE_KEY_BASE64="..."
# APPLE_WALLET_WWDR_BASE64="..."  (WWDR en base64, optionnel si déjà en PEM / chemin)

# Google Wallet (lien « Ajouter » — OAuth2 service account + API walletobjects, intégration à finaliser)
# GOOGLE_WALLET_ISSUER_ID="3388000000012345678"
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Clerk (Auth optionnel, si pas Supabase)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Stripe (configurer l'URL webhook: https://votredomaine.com/api/stripe/webhook)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_VISION="price_..."   # Vision 59€/mois (EUR)
STRIPE_PRICE_ID_PULSE="price_..."    # Pulse 97€/mois
STRIPE_PRICE_ID_ZENITH="price_..."   # Zenith 179€/mois
STRIPE_PRICE_ID_VISION_ANNUAL="price_..." # Vision facturé annuellement (-20%)
STRIPE_PRICE_ID_PULSE_ANNUAL="price_..."  # Pulse facturé annuellement (-20%)
STRIPE_PRICE_ID_ZENITH_ANNUAL="price_..." # Zenith facturé annuellement (-20%)
# Prix USD — locale /en (mêmes paliers Graduated que l’EUR)
# STRIPE_PRICE_ID_VISION_USD=...
# STRIPE_PRICE_ID_VISION_ANNUAL_USD=...
# STRIPE_PRICE_ID_PULSE_USD=...
# STRIPE_PRICE_ID_PULSE_ANNUAL_USD=...
# STRIPE_PRICE_ID_ZENITH_USD=...
# STRIPE_PRICE_ID_ZENITH_ANNUAL_USD=...
# Prix GBP — locale /en-gb
# STRIPE_PRICE_ID_VISION_GBP=...
# STRIPE_PRICE_ID_VISION_ANNUAL_GBP=...
# STRIPE_PRICE_ID_PULSE_GBP=...
# STRIPE_PRICE_ID_PULSE_ANNUAL_GBP=...
# STRIPE_PRICE_ID_ZENITH_GBP=...
# STRIPE_PRICE_ID_ZENITH_ANNUAL_GBP=...
# Prix JPY — locale /ja (voir aussi targets/settings.json > billing.plans.*.prices.JPY)
# STRIPE_PRICE_ID_VISION_JPY=...
# STRIPE_PRICE_ID_VISION_ANNUAL_JPY=...
# STRIPE_PRICE_ID_PULSE_JPY=...
# STRIPE_PRICE_ID_PULSE_ANNUAL_JPY=...
# STRIPE_PRICE_ID_ZENITH_JPY=...
# STRIPE_PRICE_ID_ZENITH_ANNUAL_JPY=...
# Prix CAD — locales *-ca (Catalogue : targets/settings.json > billing.plans.*.prices.CAD)
# STRIPE_PRICE_ID_VISION_CAD=...
# STRIPE_PRICE_ID_VISION_ANNUAL_CAD=...
# STRIPE_PRICE_ID_PULSE_CAD=...
# STRIPE_PRICE_ID_PULSE_ANNUAL_CAD=...
# STRIPE_PRICE_ID_ZENITH_CAD=...
# STRIPE_PRICE_ID_ZENITH_ANNUAL_CAD=...
# Prix AUD — locales *-au (Catalogue : billing.plans.*.prices.AUD)
# STRIPE_PRICE_ID_VISION_AUD=...
# STRIPE_PRICE_ID_VISION_ANNUAL_AUD=...
# STRIPE_PRICE_ID_PULSE_AUD=...
# STRIPE_PRICE_ID_PULSE_ANNUAL_AUD=...
# STRIPE_PRICE_ID_ZENITH_AUD=...
# STRIPE_PRICE_ID_ZENITH_ANNUAL_AUD=...
# Optionnel — MRR admin (conversion vers EUR) : défauts 0.92 / 1.17 / 0.0062 (JPY) / 0.63 (CAD) / 0.58 (AUD)
# INVESTOR_FX_USD_EUR=0.92
# INVESTOR_FX_GBP_EUR=1.17
# INVESTOR_FX_JPY_EUR=0.0062
# INVESTOR_FX_CAD_EUR=0.63
# INVESTOR_FX_AUD_EUR=0.58
# Optionnel — CPA admin : dépense marketing mensuelle (EUR) ÷ nouveaux profils marchands (30 j.)
# INVESTOR_MARKETING_SPEND_MONTHLY_EUR=5000
STRIPE_ADDON_PRODUCT_ID="prod_..."   # Produit Stripe pour les addons établissements (créer "REPUTEXA Addon")

# App URL (pour redirections OAuth, Stripe, emails)
# En prod Vercel : https://votre-app.vercel.app (sans slash final)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Avis Google Business — fiche REPUTEXA (bouton « Publier sur Google » dans le dashboard)
# NEXT_PUBLIC_REPUTEXA_GOOGLE_REVIEW_URL="https://g.page/r/.../review"

# Page publique /{locale}/impressum (Anbieterkennzeichnung, TVA, etc.)
# NEXT_PUBLIC_IMPRESSUM_LEGAL_NAME="REPUTEXA SAS"
# NEXT_PUBLIC_IMPRESSUM_ADDRESS="123 rue Exemple\n75001 Paris\nFrance"
# NEXT_PUBLIC_IMPRESSUM_CONTACT="contact@reputexa.fr"
# NEXT_PUBLIC_IMPRESSUM_VAT="FRXX999999999"

# Sentinel — test webhooks /api/health depuis l’URL publique (prioritaire sur NEXT_PUBLIC_*)
# En local sans NEXT_PUBLIC_SITE_URL : mettez votre URL de prod pour valider les webhooks.
# SENTINEL_PUBLIC_URL="https://reputexa.fr"

# Resend (emails J+0, J-3, J-0)
RESEND_API_KEY="re_..."
# Format strict : "REPUTEXA <email@reputexa.fr>"
RESEND_FROM="REPUTEXA <noreply@reputexa.fr>"
RESEND_TRIAL_REMINDER_FROM="REPUTEXA <contact@reputexa.fr>"
# Newsletter — Audience Resend (Resend Dashboard → Audiences)
RESEND_NEWSLETTER_AUDIENCE_ID="bf66991d-0d52-48ec-b086-7ec20a7c86ce"
# Si absent : `interface.resend_newsletter_audience_name` dans targets/settings.json
RESEND_NEWSLETTER_AUDIENCE_NAME="REPUTEXA_ALERTS"

# Forge blog hebdo — par défaut publication mardi seulement si statut « approved » en base.
# Mettre à true uniquement pour tests (publie même un brouillon non validé).
# BLOG_FORGE_PUBLISH_WITHOUT_APPROVAL=false

# Sync Resend → newsletter_subscribers (après migration 172) : npm run newsletter:sync-resend
# NEWSLETTER_SYNC_DEFAULT_LOCALE=fr
# NEWSLETTER_SYNC_RESPECT_EXISTING=1  — ne pas écraser la locale déjà stockée en base

# Cron (trial emails) — Vercel Cron envoie ce header ; ou cron-job.org avec Authorization: Bearer <CRON_SECRET>
CRON_SECRET="votre-secret-fort"
# Rétention des clés d’idempotence terminal Banano (cron quotidien banano-loyalty-idempotency-prune). Entre 7 et 365 j., défaut 30.
# BANANO_IDEMPOTENCY_RETENTION_DAYS=30

# Sentinel Vault + Black Box — même famille de variables (bucket chiffré + tiering froid).
# BACKUP_S3_BUCKET, BACKUP_S3_ACCESS_KEY_ID, BACKUP_S3_SECRET_ACCESS_KEY, BACKUP_S3_REGION (ex. auto sur R2)
# R2 : BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com — path-style activé auto si endpoint présent (ou BACKUP_S3_FORCE_PATH_STYLE=1)
# SENTINEL_VAULT_AES_KEY : clé AES du Vault uniquement (pas utilisée par Black Box gzip seul).

# Black Box Archive — tiering froid (gzip → même bucket BACKUP_S3_* / R2 que Sentinel Vault si configuré)
# BLACK_BOX_ARCHIVE_ENABLED=1
# Rétention « hot » : seules les lignes PLUS VIEILLES que N jours sont archivées (min. 7 côté code). Tout récent → 0 lot.
# BLACK_BOX_HOT_RETENTION_DAYS=30
# BLACK_BOX_BATCH_ROWS=400
# BLACK_BOX_AI_SUMMARY=1
# BLACK_BOX_S3_STORAGE_CLASS=INTELLIGENT_TIERING

# Forge — injection snippets + auto-validation réponses avis
# FORGE_INJECTION_ENABLED=1
# FORGE_SKIP_QUALITY_GATE_AT=90
# FORGE_REVIEW_ESCALATE_BELOW=80
# FORGE_SENTINEL_INJECT=1
# FORGE_BABEL_AUTOPILOT=1

# Babel Guardian — transcréation messages / wizard (Native-Perfect)
# BABEL_TRANSCREATE_MODEL=gpt-4o-mini
# Guide terminologique : défaut lib/generated/product-ai-context.txt puis repli product-ai-context.txt à la racine
# BABEL_PRODUCT_CONTEXT_PATH=lib/generated/product-ai-context.txt
# BABEL_PRODUCT_CONTEXT_MAX_CHARS=48000
# Auto-critique « robot vs natif » avant fusion du lot (désactiver : 0 / false)
# BABEL_NATIVE_CRITIQUE_ENABLED=1
# Timeout HTTP OpenAI par requête (lots volumineux, ms) — le script impose un minimum de 1 800 000 ms
# BABEL_OPENAI_TIMEOUT_MS=900000
# Plafond de sortie JSON (transcréation / auto-critique), max. 32768
# BABEL_MAX_COMPLETION_TOKENS=32768

# Omni-Synapse (mémoire vectorielle + ingest Edge) — optionnel pour la fonction Deno dédiée
# OMNI_INGEST_SECRET="secret-partagé-ingest"

# Stripe : créer un code promo -10% "REPUTEXA10" (Dashboard Stripe → Produits → Coupons)

# Admin — Centre de Conformité Légal-AI
# Clé secrète admin pour les API admin (legal publish, ai-tools, etc.)
ADMIN_SECRET="votre-secret-admin-fort"

# Growth / Instantly — poussée prospects + webhooks ouverture & clic (même secret en header x-outreach-secret ou Bearer)
# INSTANTLY_API_KEY="…"
# OUTREACH_WEBHOOK_SECRET="chaîne-longue-aléatoire"

# Grand Central — mur IP + liaison navigateur (optionnel ; vide = désactivé)
# IPs autorisées pour toutes les pages /…/dashboard/admin et pour /api/admin/* (virgules).
# Formes supportées : IPv4 exacte, IPv6 exacte, CIDR IPv4 (ex. 203.0.113.0/24).
# En prod : noter l’IP vue par Vercel (première valeur de x-forwarded-for en général).
# Requêtes avec Authorization: Bearer CRON_SECRET ou ADMIN_SECRET contournent le mur IP (scripts / auto-heal).
# ADMIN_ALLOWED_IPS="203.0.113.10,198.51.100.0/24"
# Secret HMAC pour cookie httpOnly grand_central_bind (environ 32+ octets aléatoires). Si vide : pas de contrôle d’environnement client sur l’admin.
# GRAND_CENTRAL_BIND_SECRET="générez-une-chaîne-longue-et-aléatoire"
# Alertes email/Telegram (même canal que Sentinel) quand une requête admin est bloquée (IP) ou liaison rompue.
# POST /api/internal/grand-central-intrusion avec Bearer ce secret — ne pas exposer au front.
# GRAND_CENTRAL_ALERT_SECRET="autre-secret-dédié-aux-alertes"
# Auth « zéro mot de passe » : inscription + connexion magic link = e-mails envoyés via Resend (templates Zenith), pas SMTP Supabase.
# Dans Supabase → Auth → Email : templates compatibles lien magique ({{ .ConfirmationURL }} ou équivalent selon doc).
# Passkeys / WebAuthn : Authentication → MFA ; optionnel après première session (Réglages ou écran consentement).
# pour le compte admin après une première connexion mot de passe. Phrase de passe longue + MFA matériel / biométrie + ADMIN_ALLOWED_IPS = stratégie « forteresse ».
# Email admin pour les test-sends (aperçu email avant publication globale)
ADMIN_EMAIL="admin@reputexa.fr"
# Alertes Legal Guardian / conformité (prioritaire sur ADMIN_EMAIL puis 1er profil role=admin)
# ADMIN_COMPLIANCE_EMAIL="vous@domaine.fr"
# Locale des textes admin générés côté serveur (e-mails Guardian, digest Council, contexte Forge Babel autopilot)
# ADMIN_PANEL_LOCALE="fr"
# LEGAL_GUARDIAN_SILENT_OK=1 — pas d’e-mail quand le cycle Guardian se termine sans alerte
# LEGAL_GUARDIAN_SILENT_ALL=1 — désactive tous les e-mails Guardian (débug)
# Publication légale (IA) — les appels passent par le serveur (Vercel) avec ANTHROPIC_API_KEY ; Cursor n’est pas utilisé.
# Optionnel : modèle Claude dédié aux actions légales (sinon modèle par défaut du projet).
# LEGAL_ANTHROPIC_MODEL=claude-sonnet-4-6
# Optionnel : préremplir l’éditeur dans les prompts (sinon placeholders [À compléter]).
# LEGAL_PUBLISHER_NAME="REPUTEXA SAS"
# LEGAL_PUBLISHER_LEGAL_FORM="SAS"
# LEGAL_PUBLISHER_ADDRESS="…"
# LEGAL_PUBLISHER_RCS="RCS …"
# LEGAL_PUBLISHER_SHARE_CAPITAL="1 000 €"
# LEGAL_PUBLISHER_DIRECTOR="…"
# LEGAL_DPO_EMAIL="dpo@…"
# LEGAL_HOSTING_LINE="Vercel Inc. — …"
# LEGAL_MEDIATION_INFO="Médiateur / lien Portal — …"

# Sentinel Auto-Guérison (health-check toutes les 10min + alertes critiques)
# Email de l'admin qui reçoit les alertes rouges (peut être identique à RESEND_FROM)
SENTINEL_ALERT_EMAIL="admin@reputexa.fr"
# Telegram (optionnel) — créer un bot sur @BotFather puis récupérer le chat_id via /getUpdates
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="123456789"

# Agent d'Auto-Réparation Claude 3.5 (Sentinel Phase 2 + Auto-Heal PR)
# GitHub Personal Access Token — Scopes OBLIGATOIRES :
#   • Contents: Read & Write    (lire/écrire les fichiers source)
#   • Pull Requests: Read & Write (créer des PRs correctives)
#   • Metadata: Read (accès repo)
# Créer sur https://github.com/settings/tokens → "Fine-grained tokens" → sélectionner le repo
GITHUB_TOKEN="ghp_..."
GITHUB_REPO="username/aaaempire-reputation-ai"   # owner/repo (ex: dubut/aaaempire-reputation-ai)
GITHUB_BRANCH="main"                               # Branche de base (les PRs ciblent cette branche)
# Vercel Deploy Hook — Créer via Dashboard Vercel → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL="https://api.vercel.com/v1/integrations/deploy/prj_..."

# Twilio WhatsApp (alertes avis négatifs + collecte conversation)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
# Sandbox de test (Twilio) : +14155238886 — en production, remplacer par votre numéro WhatsApp Business approuvé (ex. +33…)
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Ou TWILIO_WHATSAPP_NUMBER="+14155238886"
# Template Content API (variables: {{1}}=Auteur avis, {{2}}=Contenu avis, {{3}}=Suggestion IA)
# TWILIO_WHATSAPP_ALERT_CONTENT_SID="HXe5963abb10fdbc94f6727dc9eb2900b0"
#
# Console Twilio : Messaging → intégration WhatsApp → « When a message comes in »
#   → POST https://reputexa.fr/api/webhooks/whatsapp-incoming (ou /api/webhooks/whatsapp-reply selon votre config)
# Webhook Twilio (réponses) : POST https://votredomaine.com/api/webhooks/whatsapp-reply

# Meta WhatsApp Cloud API (boutons interactifs Publier / Modifier — optionnel ; sinon fallback texte Twilio)
WHATSAPP_META_PHONE_NUMBER_ID=""
WHATSAPP_META_ACCESS_TOKEN=""
# Vérification du webhook Meta (challenge) — même valeur que dans le dashboard Meta
WHATSAPP_VERIFY_TOKEN=""

# Invitations salariés (e-mail technique staff-inv-…@domaine ; aligner le domaine sur votre config Auth)
# STAFF_INVITE_EMAIL_DOMAIN=reputexa.fr
# Web Push salarié (phase envoi dispatch : `npx web-push generate-vapid-keys`)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
