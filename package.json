{
  "name": "reputexa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compliance-kit:sync": "tsx scripts/sync-compliance-kit-public.ts",
    "product:ai-context": "node scripts/generate-product-ai-context.mjs",
    "postinstall": "prisma generate",
    "dev": "npm run compliance-kit:sync && npm run product:ai-context && next dev",
    "dev:poll": "npm run compliance-kit:sync && npm run product:ai-context && WATCHPACK_POLLING=true next dev",
    "dev:with-prisma": "npm run db:generate && npm run dev",
    "dev:webpack": "npm run compliance-kit:sync && npm run product:ai-context && next dev",
    "dev:turbo": "npm run compliance-kit:sync && npm run product:ai-context && next dev --turbo",
    "dev:lite": "next dev",
    "dev:lite:fresh": "node scripts/clean-next.mjs && next dev",
    "dev:lite:poll": "WATCHPACK_POLLING=true next dev",
    "dev:lite:turbo": "next dev --turbo",
    "dev:clean": "node scripts/clean-next.mjs && npm run dev",
    "clean:next": "node scripts/clean-next.mjs",
    "build": "npm run compliance-kit:sync && npm run product:ai-context && npm run support:index-codebase && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "sniper": "tsx scripts/sniper.ts",
    "nearby-research": "tsx scripts/nearby-places-research.ts",
    "support:index-codebase": "tsx scripts/index-support-codebase.ts",
    "support:watch-kb": "python scripts/watch_support_vectorizer.py",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "seed:garage-f1": "tsx scripts/seed-garage-f1.ts",
    "babel-clean": "node scripts/babel-clean.mjs",
    "babel-deploy": "tsx scripts/babel-deploy.ts",
    "babel-smart-merge": "tsx scripts/babel-smart-merge.ts",
    "babel-regenerate-locale": "tsx scripts/babel-regenerate-messages-locale.ts",
    "i18n:sync-locale": "tsx scripts/sync-messages-from-fr.ts",
    "i18n:sync-all-from-fr": "tsx scripts/sync-all-messages-from-fr.ts",
    "newsletter:sync-resend": "tsx scripts/sync-resend-to-db.ts"
  },
