    "react-phone-number-input": "^3.4.16",
    "react-turnstile": "^1.1.5",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "twilio": "^5.12.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-plugin-i18next": "^6.1.3",
