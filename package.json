    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.34.5",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "libphonenumber-js": "1.12.41",
    "lucide-react": "^0.575.0",
    "nanoid": "^3.3.11",
    "next": "14.2.35",
    "next-intl": "^3.26.5",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "passkit-generator": "^3.5.7",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "qrcode": "^1.5.4",
    "react": "^18",
