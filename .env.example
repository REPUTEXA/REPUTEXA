# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/reputexa?schema=public"

# OpenAI
OPENAI_API_KEY="sk-..."

# Google Maps / Places (autocomplétion adresse + Sniper)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."
MAPS_API_KEY="AIza..."

# Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # Optionnel: pour vérifier l'éligibilité à l'essai (anti-abus)

# Clerk (Auth optionnel, si pas Supabase)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Stripe (configurer l'URL webhook: https://votredomaine.com/api/stripe/webhook)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_VISION="price_..."   # Vision 59€/mois
STRIPE_PRICE_ID_PULSE="price_..."    # Pulse 97€/mois
STRIPE_PRICE_ID_ZENITH="price_..."   # Zenith 157€/mois

# App URL (pour redirections OAuth, Stripe, emails)
# En prod Vercel : https://votre-app.vercel.app (sans slash final)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (emails J+0, J-3, J-0)
RESEND_API_KEY="re_..."
RESEND_FROM="REPUTEXA <noreply@votredomaine.com>"

# Cron (trial emails) — Vercel Cron envoie ce header ; ou cron-job.org avec Authorization: Bearer <CRON_SECRET>
CRON_SECRET="votre-secret-fort"

# Stripe : créer un code promo -10% "REPUTEXA10" (Dashboard Stripe → Produits → Coupons)

# Twilio WhatsApp (alertes avis négatifs)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
# Template Content API (variables: {{1}}=Auteur avis, {{2}}=Contenu avis, {{3}}=Suggestion IA)
# TWILIO_WHATSAPP_ALERT_CONTENT_SID="HXe5963abb10fdbc94f6727dc9eb2900b0"
# Webhook Twilio pour les réponses utilisateur (texte/vocal) : POST https://votredomaine.com/api/webhooks/whatsapp-reply
